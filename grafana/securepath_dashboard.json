          {"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "FindingsMedium", "dimensions": {"Project": "securepath"}, "statistics": ["Sum"], "period": "3600", "refId": "C", "alias": "MEDIUM"}
        ]
      },
      {
        "id": 7, "type": "timeseries", "title": "Drift Detection Events",
        "gridPos": {"x": 0, "y": 12, "w": 12, "h": 6},
        "fieldConfig": {"defaults": {"unit": "none", "custom": {"lineWidth": 2, "fillOpacity": 15}}},
        "targets": [
          {"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "DriftDetected", "dimensions": {"Project": "securepath"}, "statistics": ["Sum"], "period": "3600", "refId": "A", "alias": "Detected"},
          {"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "DriftRemediated", "dimensions": {"Project": "securepath"}, "statistics": ["Sum"], "period": "3600", "refId": "B", "alias": "Remediated"}
