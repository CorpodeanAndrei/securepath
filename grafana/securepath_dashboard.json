{
  "dashboard": {
    "title": "SecurePath — Cloud Security Posture",
    "tags": ["securepath", "aws", "security"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "id": 1, "type": "stat", "title": "CSPS — Cloud Security Posture Score",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
        "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "orange", "value": 40}, {"color": "yellow", "value": 60}, {"color": "green", "value": 80}]}, "unit": "none", "min": 0, "max": 100}},
        "targets": [{"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "CSPS", "dimensions": {"Project": "securepath"}, "statistics": ["Average"], "period": "300", "refId": "A"}]
      },
      {
        "id": 2, "type": "stat", "title": "CRITICAL Findings",
        "gridPos": {"x": 6, "y": 0, "w": 5, "h": 4},
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
        "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}, "unit": "none"}},
        "targets": [{"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "FindingsCritical", "dimensions": {"Project": "securepath"}, "statistics": ["Sum"], "period": "86400", "refId": "A"}]
      },
      {
        "id": 3, "type": "stat", "title": "HIGH Findings",
        "gridPos": {"x": 11, "y": 0, "w": 5, "h": 4},
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
        "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 1}]}, "unit": "none"}},
        "targets": [{"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "FindingsHigh", "dimensions": {"Project": "securepath"}, "statistics": ["Sum"], "period": "86400", "refId": "A"}]
      },
      {
        "id": 4, "type": "stat", "title": "Auto-Remediated",
        "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
        "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": 0}]}, "unit": "none"}},
        "targets": [{"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "DriftRemediated", "dimensions": {"Project": "securepath"}, "statistics": ["Sum"], "period": "86400", "refId": "A"}]
      },
      {
        "id": 5, "type": "bargauge", "title": "Security Score per Layer",
