        "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "orange", "value": 40}, {"color": "yellow", "value": 60}, {"color": "green", "value": 80}]}, "unit": "none", "min": 0, "max": 100}},
        "targets": [
          {"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "LayerScore", "dimensions": {"Project": "securepath", "Layer": "supply_chain"}, "statistics": ["Average"], "period": "300", "refId": "A", "alias": "L1 Supply Chain"},
          {"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "LayerScore", "dimensions": {"Project": "securepath", "Layer": "iam_zero_trust"}, "statistics": ["Average"], "period": "300", "refId": "B", "alias": "L2 Zero-Trust IAM"},
          {"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "LayerScore", "dimensions": {"Project": "securepath", "Layer": "drift_detector"}, "statistics": ["Average"], "period": "300", "refId": "C", "alias": "L3 Drift Detector"},
          {"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "LayerScore", "dimensions": {"Project": "securepath", "Layer": "policy_engine"}, "statistics": ["Average"], "period": "300", "refId": "D", "alias": "L4 Policy Engine"},
          {"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "LayerScore", "dimensions": {"Project": "securepath", "Layer": "chaos_prober"}, "statistics": ["Average"], "period": "300", "refId": "E", "alias": "L5 Chaos Prober"}
        ]
      },
      {
        "id": 6, "type": "timeseries", "title": "Findings by Severity — Timeline",
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
        "options": {"tooltip": {"mode": "multi"}},
        "fieldConfig": {"defaults": {"unit": "none", "custom": {"lineWidth": 2, "fillOpacity": 10}}},
        "targets": [
          {"datasource": "cloudwatch", "namespace": "SecurePath", "metricName": "FindingsCritical", "dimensions": {"Project": "securepath"}, "statistics": ["Sum"], "period": "3600", "refId": "A", "alias": "CRITICAL"},
